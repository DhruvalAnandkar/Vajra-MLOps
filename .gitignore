# ============================================================
# Vajra MLOps — Comprehensive .gitignore
# ============================================================

# ============================================================
# SECURITY — CRITICAL: Never commit secrets
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ============================================================
# Python / Backend
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual Environments
.venv/
venv/
env/
.env/
ENV/

# Testing & Coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.egg-info/
dist/
*.egg

# Alembic local migration versions (generated per environment)
alembic/versions/

# ============================================================
# ML Models / Artifacts
# ============================================================
# Ignore model binaries — track the empty folder via .gitkeep
models/*
!models/.gitkeep
*.pkl
*.joblib

# Keep production registry — it defines runtime state
!production_registry.json

# ============================================================
# Frontend / Node.js
# ============================================================
node_modules/
frontend/node_modules/

# Vite / React Build Outputs
dist/
build/
frontend/dist/
frontend/build/
.vite/

# Linting caches
.eslintcache

# Node logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# Database & Infrastructure Volumes
# ============================================================
pgdata/
redpanda_data/
docker_data/
db_data/
kafka_data/

# ============================================================
# OS / IDE artifacts
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user

# ============================================================
# Miscellaneous
# ============================================================
.ipynb_checkpoints/
/tmp/
