FROM node:18-alpine

WORKDIR /app

# Copy package files strictly
COPY package.json package-lock.json* ./

RUN npm install

# Copy source code
COPY . .

# Expose Vite Port
EXPOSE 5173

# Run vite dev server listening on all hosts so host machine can access docker mapped port
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
